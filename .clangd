# compile_commands.json is generated by UBT to the Engine root (D:/UE/UE/UE_5.4/)
# Run GenerateCompileCommands.bat to refresh it after adding/removing source files.
CompileFlags:
  # Remove flags clangd doesn't understand (MSVC-specific)
  Remove:
    - /W4
    - /WX
    - /wd*
    - /Zm*
    - /fp:*
    - /GR-
    - /errorReport:*
    - /source-charset:*
    - /execution-charset:*
  Add:
    - -std=c++20
    - -DPLATFORM_WINDOWS=1

Diagnostics:
  # Suppress warnings from UE engine headers (not our code)
  Suppress:
    - pp_file_not_found
  UnusedIncludes: None

Index:
  Background: Build
